MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=biolid/esp32/sensor_data

INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-token
INFLUXDB_ORG=biolid
INFLUXDB_BUCKET=sensor_data

REDIS_URL=redis://localhost:6379/0

LLM_PROVIDER=dashscope
LLM_DIALOG_MODEL=qwen2.5-7b-instruct
LLM_DIALOG_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_BASE=http://localhost:11434

DASHSCOPE_API_KEY=your-dashscope-api-key-here

VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_PATH=./data/db/chroma_db
CHROMA_COLLECTION_NAME=health_knowledge
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
